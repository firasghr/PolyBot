# PolyBot — Application environment variables
# Copy this to .env and fill in your real values.
# NEVER commit the real .env file to source control.

# ---- Polymarket API ----
POLYMARKET_CLOB_API=https://clob.polymarket.com
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
# API key from https://clob.polymarket.com (leave empty for public endpoints)
POLYMARKET_CLOB_API_KEY=

# ---- Polygon / PolygonScan ----
POLYGONSCAN_API=https://api.polygonscan.com/api
POLYGONSCAN_API_KEY=

# ---- Wallet Discovery ----
MIN_TRADES=100
MIN_WIN_RATE=0.60
TOP_N=10
MAX_CONCURRENT_REQUESTS=8
REQUEST_TIMEOUT=15

# ---- Risk Management ----
# Kelly mode: full | half | quarter
KELLY_MODE=half

# ---- Trade Execution ----
POLL_INTERVAL_MS=500
MAX_EXECUTION_RETRIES=3
RETRY_BACKOFF_SECONDS=1.0
MIN_ORDER_BOOK_DEPTH=100.0
# Set to true to run without sending real orders
DRY_RUN=true

# ---- Paper Trading Simulator ----
SIM_SLIPPAGE_PCT=0.02
SIM_LATENCY_MS=200

# ---- Dashboard / API server ----
PORTFOLIO_VALUE_USDC=50000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Telegram Alerts ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
