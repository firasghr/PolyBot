node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/

# Docker
*.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Databases
*.db
*.sqlite
